generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  petMemberships PetMember[]
  discussions    Discussion[]
  discussionComments DiscussionComment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PetMember {
  id      String  @id @default(cuid())
  petId   String
  userId  String
  role    String  @default("CARETAKER") // "OWNER" | "CARETAKER"
  canView Boolean @default(true)
  canEdit Boolean @default(false)

  pet  Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([petId, userId])
}

model Pet {
  id               String    @id @default(cuid())
  name             String
  species          String    @default("dog")
  breed            String?
  dob              DateTime?
  weight           Float?
  sex              String?
  notes            String?
  avatarUrl        String?
  chipNumber       String?
  motherChipNumber String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  careRecords   CareRecord[]
  feedRecords   FeedRecord[]
  feedPlans     FeedPlan[]
  healthRecords HealthRecord[]
  expenses      Expense[]
  feedReviews    FeedReview[]
  members        PetMember[]
  weightRecords  WeightRecord[]
  dailyHealthLog DailyHealthLog[]
}

model CareRecord {
  id           String   @id @default(cuid())
  petId        String
  pet          Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  date         DateTime @default(now())
  type         String
  durationMins Int?
  notes        String?
  createdAt    DateTime @default(now())

  expenses Expense[]
}

model FeedPlan {
  id          String   @id @default(cuid())
  petId       String
  pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  foodName    String
  brand       String?
  amountGrams Float
  frequency   String
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeedRecord {
  id          String   @id @default(cuid())
  petId       String
  pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  date        DateTime @default(now())
  foodName    String
  amountGrams Float
  mealTime    String?
  notes       String?
  createdAt   DateTime @default(now())

  expenses Expense[]
}

model HealthRecord {
  id               String    @id @default(cuid())
  petId            String
  pet              Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  date             DateTime  @default(now())
  type             String
  title            String
  description      String?
  vetName          String?
  nextDueDate      DateTime?
  reminderInterval String?   // "yearly", "6months", "3months", "monthly"
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  expenses Expense[]
}

model Expense {
  id             String        @id @default(cuid())
  petId          String
  pet            Pet           @relation(fields: [petId], references: [id], onDelete: Cascade)
  date           DateTime      @default(now())
  category       String
  amount         Float
  description    String
  notes          String?
  invoiceNumber  String?       // Taiwan uniform invoice number (統一發票號碼)
  careRecordId   String?
  careRecord     CareRecord?   @relation(fields: [careRecordId], references: [id])
  feedRecordId   String?
  feedRecord     FeedRecord?   @relation(fields: [feedRecordId], references: [id])
  healthRecordId String?
  healthRecord   HealthRecord? @relation(fields: [healthRecordId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model FeedReview {
  id        String   @id @default(cuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  foodName  String
  brand     String?
  rating    Int      // 1-5
  review    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeightRecord {
  id        String   @id @default(cuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  weight    Float    // in kg
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyHealthLog {
  id             String   @id @default(cuid())
  petId          String
  pet            Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  date           DateTime
  weight         Float?   // in kg
  appetite       String?  // "excellent" | "good" | "reduced" | "poor"
  stoolCondition String?  // "normal" | "soft" | "diarrhea" | "constipation"
  mood           String?  // "energetic" | "normal" | "lethargic"
  hasVomiting    Boolean  @default(false)
  temperature    Float?   // in celsius
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([petId, date])
  @@index([petId, date])
}

model Discussion {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title     String
  content   String
  category  String   // "feed" | "medication" | "fresh_food" | "supplement"
  imageUrls String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments DiscussionComment[]

  @@index([category])
  @@index([authorId])
}

model DiscussionComment {
  id           String     @id @default(cuid())
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  authorId     String
  author       User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([discussionId])
}

